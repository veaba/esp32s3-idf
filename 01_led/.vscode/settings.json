{
  "cSpell.words": [
    "fdiagnostics",
    "ffast",
    "SRCS"
  ],
  "idf.currentSetup": "${env:IDF_PATH}",
  "idf.portWin": "COM4",
  "C_Cpp.default.includePath": [
    "${workspaceFolder}/**",
    "${env:IDF_PATH}/components/**"
  ],
  "idf.flashType": "UART",
  "idf.openOcdConfigs": [
    "board/esp32s3-builtin.cfg"
  ],
  "idf.customExtraVars": {
    "IDF_TARGET": "esp32s3"
  },
  "clangd.path": "clangd",
  "clangd.arguments": [
    "--background-index",
    "--query-driver=**",
    "--compile-commands-dir=${workspaceFolder}/build"
  ],
  "C_Cpp.intelliSenseEngine": "disabled"
}